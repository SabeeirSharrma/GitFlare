#!/usr/bin/env python3
"""Git credential helper for GitFlare.

This script is installed to PATH so Git can find it as "gitflare" helper.
It uses the system keychain to store and retrieve tokens.
"""

import sys
import keyring

SERVICE_PREFIX = "gitflare"


def parse_input() -> dict:
    """Parse key=value pairs from stdin."""
    data = {}
    for line in sys.stdin:
        line = line.strip()
        if not line:
            break
        key, _, value = line.partition("=")
        data[key] = value
    return data


def main():
    """Main entry point."""
    action = sys.argv[1] if len(sys.argv) > 1 else ""
    data = parse_input()
    host = data.get("host", "")
    service = f"{SERVICE_PREFIX}:{host}"

    if action == "get":
        token = keyring.get_password(service, "gitflare")
        if token:
            print("username=gitflare")
            print(f"password={token}")

    elif action == "store":
        token = data.get("password", "")
        if token:
            keyring.set_password(service, "gitflare", token)

    elif action == "erase":
        try:
            keyring.delete_password(service, "gitflare")
        except keyring.errors.PasswordDeleteError:
            pass


if __name__ == "__main__":
    main()
